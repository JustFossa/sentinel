# ============================================================================
# Sentinel configuration
# Copy to `.env` and fill in for LIVE mode. Mock mode needs NONE of these.
# ============================================================================

# --- Run mode --------------------------------------------------------------
# mock = fully offline demo (no keys, no network). live = real Foundry + MCP.
SENTINEL_MODE=mock

# --- Microsoft Foundry / Azure OpenAI (reasoning model) --------------------
# Reasoning model deployment. GPT-5.2 and MAI-Thinking-1 are the recommended
# reasoning models in Foundry for multi-step agentic problem solving.
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-04-01-preview
SENTINEL_MODEL_DEPLOYMENT=gpt-5.2

# --- Azure MCP Server ------------------------------------------------------
# Gives the agent Azure context across 40+ services (App Insights logs via KQL,
# Azure Monitor metrics, resource health). Started via `npx -y @azure/mcp server start`.
AZURE_MCP_COMMAND=npx
AZURE_MCP_ARGS=-y,@azure/mcp@latest,server,start
# Used by Azure MCP / azure-identity for auth (DefaultAzureCredential also works):
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=

# --- GitHub MCP Server (deploy / PR correlation) ---------------------------
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/
GITHUB_PERSONAL_ACCESS_TOKEN=
GITHUB_REPO=your-org/your-service

# --- Observability ---------------------------------------------------------
# Point at your Foundry / App Insights OTLP endpoint to ship traces.
OTEL_EXPORTER_OTLP_ENDPOINT=
